{
  "name": "img2favicon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:pages": "bun scripts/generate-pages.ts",
    "generate:assets": "bun scripts/generate-public-assets.ts",
    "generate:sitemap": "bun scripts/generate-sitemap.ts",
    "build": "bun run generate:assets && bun run generate:pages && tsc --noEmit && vite build && bun run generate:sitemap",
    "deploy": "bun run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "gifenc": "^1.0.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide": "^1.21.0",
    "pdfjs-dist": "^6.0.227",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/jspdf": "^2.0.0",
    "@types/jszip": "^3.4.1",
    "@types/qrcode": "^1.5.6",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
